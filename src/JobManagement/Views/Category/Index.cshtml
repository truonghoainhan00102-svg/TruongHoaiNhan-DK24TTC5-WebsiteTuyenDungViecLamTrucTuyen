@model IEnumerable<JobManagement.Models.Category>

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-3">📂 Quản lý ngành nghề</h2>

    <p>
        @Html.ActionLink("➕ Thêm mới", "Create", null, new { @class = "btn btn-success" })
    </p>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên ngành</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.CategoryName</td>
                    <td>
                        @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-warning btn-sm" })
                        @Html.ActionLink("Xóa", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>