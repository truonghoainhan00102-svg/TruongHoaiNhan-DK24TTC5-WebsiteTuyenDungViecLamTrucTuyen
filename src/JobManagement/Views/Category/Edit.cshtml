@model JobManagement.Models.Category

<div class="container mt-4">
    <h3>✏️ Sửa ngành nghề</h3>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="mb-3">
            @Html.LabelFor(m => m.CategoryName)
            @Html.TextBoxFor(m => m.CategoryName, new { @class = "form-control" })
        </div>

        <button type="submit" class="btn btn-warning">Cập nhật</button>
        @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn btn-secondary" })
    }
</div>