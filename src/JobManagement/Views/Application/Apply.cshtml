@model JobManagement.Models.Job
@{
    ViewBag.Title = "Ứng tuyển công việc";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <h3 class="fw-bold text-success mb-3">
                        📩 Ứng tuyển: @Model.Title
                    </h3>

                    <p class="text-muted">
                        🏢 @Model.Company
                    </p>

                    <hr />

                    <form action="/Application/Apply/@Model.Id"
                          method="post"
                          enctype="multipart/form-data">

                        @Html.AntiForgeryToken()

                        <!-- Cover Letter -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Thư giới thiệu
                            </label>

                            <textarea name="coverLetter"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Giới thiệu ngắn về bạn..."
                                      required></textarea>
                        </div>

                        <!-- Upload CV -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Tải CV
                            </label>

                            <input type="file"
                                   name="cvFile"
                                   class="form-control"
                                   accept=".pdf,.doc,.docx"
                                   required />

                            <small class="text-muted">
                                Chấp nhận: PDF, DOCX
                            </small>
                        </div>

                        <!-- BUTTON -->
                        <div class="d-flex justify-content-between mt-4">

                            <a href="/Job/Details/@Model.Id"
                               class="btn btn-outline-secondary">
                                ⬅ Hủy
                            </a>

                            <button type="submit"
                                    class="btn btn-success px-4">
                                🚀 Nộp hồ sơ
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>

    </div>

</div>