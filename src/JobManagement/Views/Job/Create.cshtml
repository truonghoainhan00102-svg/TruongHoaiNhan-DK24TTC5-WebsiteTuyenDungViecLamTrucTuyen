@model JobManagement.Models.Job

@{
    ViewBag.Title = "Đăng tin tuyển dụng";
}

<div class="container mt-4">

    <h2 class="fw-bold text-primary mb-4">📢 Đăng tin tuyển dụng</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success text-center shadow-sm">
            ✔ @TempData["Message"]
        </div>
    }

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="card shadow-sm p-4">

            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="row g-3">

                <!-- Title -->
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Title, "Tiêu đề công việc")
                    @Html.TextBoxFor(m => m.Title, new { @class = "form-control", placeholder = "VD: Lập trình viên .NET" })
                    @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                </div>

                <!-- Company -->
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Company, "Công ty")
                    @Html.TextBoxFor(m => m.Company, new { @class = "form-control", placeholder = "VD: FPT Software" })
                    @Html.ValidationMessageFor(m => m.Company, "", new { @class = "text-danger" })
                </div>

                <!-- Salary -->
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Salary, "Mức lương")
                    @Html.TextBoxFor(m => m.Salary, new { @class = "form-control", placeholder = "VD: 15000000" })
                    @Html.ValidationMessageFor(m => m.Salary, "", new { @class = "text-danger" })
                </div>

                <!-- Deadline -->
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Deadline, "Hạn nộp")
                    @Html.TextBoxFor(m => m.Deadline, new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.Deadline, "", new { @class = "text-danger" })
                </div>

                <!-- Category -->
                <div class="col-md-6">
                    @Html.Label("Ngành nghề")
                    @Html.DropDownList("CategoryId", null, "-- Chọn ngành nghề --",
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "text-danger" })
                </div>

                <!-- Description -->
                <div class="col-md-12">
                    @Html.LabelFor(m => m.Description, "Mô tả công việc")
                    @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 4, placeholder = "Mô tả chi tiết công việc..." })
                    @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                </div>

            </div>

            <!-- BUTTON -->
            <div class="mt-4 d-flex justify-content-between">
                @Html.ActionLink("⬅ Quay lại", "Index", null, new { @class = "btn btn-secondary" })

                <button type="submit" class="btn btn-success px-4">
                    🚀 Đăng tin
                </button>
            </div>

        </div>
    }

</div>