<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Job System</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f7fa;
        }

        .navbar-brand {
            font-weight: bold;
            color: #0d6efd !important;
        }

        .nav-link {
            font-weight: 500;
        }

            .nav-link:hover {
                color: #0d6efd !important;
            }

        footer {
            text-align: center;
            padding: 15px;
            color: gray;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">

            <!-- LOGO -->
            @Html.ActionLink("💼 JobFinder", "Index", "Home", null, new { @class = "navbar-brand" })

            <!-- TOGGLE MOBILE -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="navbarContent">

                <!-- LEFT -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        @Html.ActionLink("Trang chủ", "Index", "Home", null, new { @class = "nav-link" })
                    </li>

                    <li class="nav-item">
                        @Html.ActionLink("Việc làm", "Index", "Job", null, new { @class = "nav-link" })
                    </li>
                </ul>

                <!-- RIGHT -->
                <ul class="navbar-nav">

                    @if (Session["FullName"] != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-primary fw-bold">
                                👋 @Session["FullName"]
                            </span>
                        </li>

                        if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Quản lý", "Index", "Users", null, new { @class = "nav-link" })
                            </li>
                        }
                        <li class="nav-item">
                            @Html.ActionLink("Tin của tôi", "MyJobs", "Job", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Ngành nghề", "Index", "Category", null, new { @class = "nav-link" })
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink("Đăng xuất", "Logout", "Account", null, new { @class = "nav-link text-danger" })
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Đăng ký", "Register", "Account", null, new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Đăng nhập", "Login", "Account", null, new { @class = "nav-link btn btn-primary text-white ms-2 px-3" })
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- BODY -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="mt-5">
        <hr />
        <p>© @DateTime.Now.Year - JobFinder</p>
    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>